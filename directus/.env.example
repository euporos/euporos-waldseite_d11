####################################################################################################
# Directus configuration — copy to .env and fill in the SECRET values.
# .env is git-ignored. See https://docs.directus.io/self-hosted/config-options/
#
# SECRETS (required, never commit):
#   DB_PASSWORD  — Postgres password for the 'directus' role
#   KEY          — random UUID, used for data encryption
#   SECRET       — random string, used for JWT signing
#
# In prod, set these in the Directus .env on the VPS (not committed).
####################################################################################################

ASSETS_TRANSFORM_IMAGE_MAX_DIMENSION=10000

HOST="0.0.0.0"
PORT=8055
# Dev: Directus is accessed directly on port 8055
# Prod: set PUBLIC_URL="https://sounds-of-ukraine.de/directus/" in CONFIG_PATH
PUBLIC_URL="http://localhost:8055"

### Database (PostgreSQL — active during the PG migration, Phase 2+)
DB_CLIENT="pg"
DB_HOST="localhost"
DB_PORT="5435"           # must match $PGPORT in flake.nix pgEnvHook
DB_DATABASE="directus"
DB_USER="directus"
DB_PASSWORD="password"

### Database (MariaDB — legacy, kept commented for rollback until post-Phase 6)
# DB_CLIENT="mysql2"
# DB_HOST="localhost"
# DB_PORT="3306"
# DB_DATABASE="festival_directus"
# DB_USER="directus"
# DB_PASSWORD="YOUR_DB_PASSWORD"

### Rate Limiting
RATE_LIMITER_ENABLED=false
RATE_LIMITER_STORE=memory
RATE_LIMITER_POINTS=25
RATE_LIMITER_DURATION=1

### Caching
CACHE_ENABLED=false
CACHE_STORE=memory
ASSETS_CACHE_TTL="30d"

### File Storage
STORAGE_LOCATIONS="local"
STORAGE_LOCAL_DRIVER="local"
STORAGE_LOCAL_ROOT="./uploads"

### Security
KEY="YOUR_DIRECTUS_KEY"
SECRET="YOUR_DIRECTUS_SECRET"

ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAME_SITE="lax"
REFRESH_TOKEN_COOKIE_NAME="directus_refresh_token"

# CORS: enabled for dev (separate ports), disable in prod (same origin via nginx).
CORS_ENABLED=true
CORS_ORIGIN=true
CORS_METHODS=GET,POST,PATCH,DELETE
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_EXPOSED_HEADERS=Content-Range
CORS_CREDENTIALS=true
CORS_MAX_AGE=18000

### Extensions
EXTENSIONS_PATH="./extensions"
EXTENSIONS_AUTO_RELOAD=false

### Email
EMAIL_FROM="no-reply@directus.io"
EMAIL_TRANSPORT="sendmail"
EMAIL_SENDMAIL_NEW_LINE="unix"
EMAIL_SENDMAIL_PATH="/usr/sbin/sendmail"
